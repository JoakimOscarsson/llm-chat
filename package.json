{
  "name": "llm-chat-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "ci:docker": "npm run ci:docker:validate && npm run ci:docker:static-analysis",
    "ci:docker:validate": "docker build -f docker/ci.Dockerfile --target validate -t llm-chat-ci:validate .",
    "ci:docker:static-analysis": "docker build -f docker/ci.Dockerfile --target static-analysis -t llm-chat-ci:static-analysis .",
    "dev": "pnpm --filter @llm-chat-app/web dev",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  }
}
